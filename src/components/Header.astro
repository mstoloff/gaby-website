---
import { NAV } from '../i18n';
import type { Locale } from '../i18n';

// Adding a new locale: add to LOCALES_META, add a key in src/i18n/index.ts
// (NAV + COMMON), add the route files, done.
interface LocaleMeta { code: Locale; label: string; prefix: string }
const LOCALES_META: LocaleMeta[] = [
  { code: 'en', label: 'EN', prefix: '' },
  { code: 'es', label: 'ES', prefix: '/es' },
  { code: 'it', label: 'IT', prefix: '/it' },
];

// Pages that exist in non-EN locales. Other routes always serve English.
const TRANSLATED_SLUGS = new Set(['', 'about']);

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const current: LocaleMeta = LOCALES_META
  .filter((l) => l.prefix === '' || path === l.prefix || path.startsWith(`${l.prefix}/`))
  .sort((a, b) => b.prefix.length - a.prefix.length)[0]!;

// Slug = the part of the path after the locale prefix, with leading '/' stripped.
const slug = (current.prefix
  ? path.slice(current.prefix.length)
  : path
).replace(/^\//, '').replace(/\/$/, '');

// Build nav links per current locale. Translated slugs route to /{prefix}/{slug}/,
// untranslated routes always go to the English /{slug}/.
const navLinks = [
  { slug: '', label: NAV[current.code].home },
  { slug: 'about', label: NAV[current.code].about },
  { slug: 'media', label: NAV[current.code].media },
  { slug: 'repertoire', label: NAV[current.code].repertoire },
  { slug: 'voice-lessons', label: NAV[current.code].voiceLessons },
  { slug: 'contact', label: NAV[current.code].contact },
];

const hrefForSlug = (s: string) => {
  const isTranslated = TRANSLATED_SLUGS.has(s);
  const prefix = isTranslated ? current.prefix : '';
  const tail = s ? `${s}/` : '';
  return `${prefix || ''}/${tail}` || '/';
};

const isActiveNav = (s: string) => s === slug;

// Locale-toggle href: stay on same page if it's translated; otherwise drop to
// the locale's homepage. Avoids 404s on toggle.
const hrefForLocale = (l: LocaleMeta) => {
  if (TRANSLATED_SLUGS.has(slug)) {
    const tail = slug ? `${slug}/` : '';
    return l.prefix ? `${l.prefix}/${tail}` : `/${tail}`;
  }
  // Untranslated page: dropping locale toggle goes to the locale's home.
  return l.prefix ? `${l.prefix}/` : '/';
};
---

<header class="site-header">
  <div class="container header-row">
    <a href={current.prefix ? `${current.prefix}/` : '/'} class="wordmark" aria-label="Gabriela Stoloff-Báez — Home">
      Gabriela Stoloff-B<span class="accent-a">á</span>ez
    </a>

    <nav class="primary" aria-label="Primary">
      <ul>
        {
          navLinks.map((l) => (
            <li>
              <a
                href={hrefForSlug(l.slug)}
                aria-current={isActiveNav(l.slug) ? 'page' : undefined}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="locale" aria-label="Language">
      {LOCALES_META.map((l, i) => (
        <>
          {i > 0 && <span aria-hidden="true">/</span>}
          <a href={hrefForLocale(l)} class:list={[{ active: l.code === current.code }]} data-locale={l.code}>
            {l.label}
          </a>
        </>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    try {
      var here = location.pathname;
      var derived = 'en';
      if (here.indexOf('/es') === 0) derived = 'es';
      else if (here.indexOf('/it') === 0) derived = 'it';
      var stored = localStorage.getItem('gsb_locale');
      if (!stored) localStorage.setItem('gsb_locale', derived);
      document.querySelectorAll('.locale a').forEach(function (a) {
        a.addEventListener('click', function () {
          localStorage.setItem('gsb_locale', a.getAttribute('data-locale'));
        });
      });
    } catch (e) {}
  })();
</script>

<style>
  .site-header {
    background: var(--color-bone);
    border-bottom: 1px solid var(--color-sand);
  }
  .header-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-top: 1.4rem;
    padding-bottom: 1.4rem;
  }
  .wordmark {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-size: 20px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    border-bottom: 0;
  }
  .wordmark:hover { color: var(--color-oxblood); }
  .accent-a { font-style: normal; }

  .primary ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
    justify-content: center;
  }
  .primary a {
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.7;
    border-bottom: 0;
  }
  .primary a:hover,
  .primary a[aria-current='page'] {
    opacity: 1;
    color: var(--color-ink);
  }
  .primary a[aria-current='page'] {
    border-bottom: 1px solid var(--color-oxblood);
    padding-bottom: 4px;
  }

  .locale {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.7;
  }
  .locale a {
    color: inherit;
    border-bottom: 0;
  }
  .locale a.active { color: var(--color-oxblood); opacity: 1; }
  .locale span { opacity: 0.4; }

  @media (max-width: 900px) {
    .header-row {
      grid-template-columns: auto auto;
      grid-template-areas: 'wordmark locale' 'nav nav';
      row-gap: 1rem;
    }
    .wordmark { grid-area: wordmark; }
    .locale { grid-area: locale; justify-self: end; }
    .primary { grid-area: nav; }
    .primary ul { justify-content: flex-start; gap: 1.1rem; }
  }
</style>
