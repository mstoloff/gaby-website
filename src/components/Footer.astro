---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>© {year} Gabriela Stoloff-Báez</p>
  <p class="links">
    <a href="https://www.instagram.com/gabriela.stoloff.baez/" target="_blank" rel="noopener noreferrer">Instagram</a>
    <span aria-hidden="true">·</span>
    <a href="mailto:gabrielastoloffbaez@gmail.com">gabrielastoloffbaez@gmail.com</a>
  </p>
</footer>

<style>
  .site-footer {
    max-width: 1080px;
    margin: 4rem auto 0;
    padding: 2rem 1.5rem;
    border-top: 1px solid #ece6d9;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .site-footer p { margin: 0; }
  .site-footer a { color: var(--color-muted); }
  .site-footer a:hover { color: var(--color-accent); }
</style>
