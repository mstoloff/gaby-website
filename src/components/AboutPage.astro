---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { ABOUT, ABOUT_META } from '../i18n/about';
import type { Locale } from '../i18n';
import headshotGarden from '../assets/images/headshot-garden.webp';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ABOUT[locale];
const meta = ABOUT_META[locale];
---

<Layout
  title={meta.title}
  description={meta.description}
  type="profile"
  locale={locale}
>
  <main>
    <section class="container about-hero">
      <p class="micro">{t.eyebrow}</p>
      <h1>{t.heading}</h1>
    </section>

    <section class="container about-grid grid12">
      <div class="bio-col">
        <p class="lede">{t.lede}</p>

        {t.paragraphs.map((p, i) => (
          <>
            <p set:html={p} />
            {i === 0 && (
              <blockquote class="pullquote about-pullquote" lang={locale}>
                {t.pullQuote}
              </blockquote>
            )}
          </>
        ))}

        <h2>{t.awardsHeading}</h2>
        <ul class="award-list">
          {t.awards.map((a) => (
            <li>
              <span class="award-year">{a.year}</span>
              <span class="award-name" set:html={a.name} />
            </li>
          ))}
        </ul>

        <h2>{t.languagesHeading}</h2>
        <p set:html={t.languagesBody} />

        <h2>{t.pressHeading}</h2>
        <p set:html={t.pressBody} />
      </div>

      <aside class="portrait-col">
        <figure class="portrait-figure">
          <Image
            src={headshotGarden}
            alt="Gabriela Stoloff-Báez, color portrait taken in a garden with dark green foliage behind."
            widths={[480, 720, 960]}
            sizes="(min-width: 1024px) 33vw, 100vw"
            format="avif"
            quality={75}
            loading="eager"
          />
          <figcaption class="caption">{t.portraitCaption}</figcaption>
        </figure>
        {/* Reserved slot for the future environmental portrait. */}
      </aside>
    </section>
  </main>
</Layout>

<style>
  main { padding-top: 1.5rem; }

  .about-hero {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }
  .about-hero h1 {
    margin-top: 1rem;
    font-size: clamp(48px, 6.5vw, 84px);
    line-height: 1.04;
  }

  .about-grid {
    align-items: start;
    padding-bottom: 5rem;
  }
  .bio-col { grid-column: 1 / span 7; }
  .portrait-col {
    grid-column: 9 / span 4;
    position: sticky;
    top: 2rem;
  }
  .portrait-figure { margin: 0; }
  .portrait-figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .lede {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-size: clamp(20px, 2vw, 24px);
    line-height: 1.45;
    margin: 0 0 2rem;
    color: var(--color-ink);
  }

  .about-pullquote {
    margin: 2.5rem 0;
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-oxblood);
  }

  .bio-col h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: clamp(26px, 2.4vw, 30px);
  }

  .award-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .award-list li {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.25rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-sand);
  }
  .award-list li:first-child {
    border-top: 1px solid var(--color-sand);
  }
  .award-year {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-style: italic;
    color: var(--color-oxblood);
    font-size: 17px;
  }

  @media (max-width: 900px) {
    .bio-col { grid-column: 1 / -1; }
    .portrait-col {
      grid-column: 1 / -1;
      position: static;
      max-width: 360px;
      margin-bottom: 2.5rem;
      order: -1;
    }
  }
</style>
