---
import Layout from '../layouts/Layout.astro';
import Page from '../components/Page.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Voice Lessons — Junior (ages 12–18)',
  provider: { '@id': 'https://www.gabrielastoloffbaez.com/#person' },
  audience: {
    '@type': 'Audience',
    audienceType: 'Singers ages 12–18',
  },
  description:
    'Voice lessons with Gabriela Stoloff-Báez (Oberlin, SFCM) for the changing and developing voice. Healthy vocal production and musicianship for singers ages 12 through 18.',
};
---

<Layout
  title="Voice Lessons — Gabriela Stoloff-Báez"
  description="Voice lessons with Gabriela Stoloff-Báez for singers ages 12–18. Healthy vocal production and musicianship for the changing and developing voice."
  jsonLd={jsonLd}
>
  <Page
    title="Voice Lessons"
    lead="Junior Lessons — designed for singers ages 12–18."
  >
    <p>
      I've created a course on healthy vocal production and musicianship for the
      changing and developing voice. Drawing on my experience teaching over 100
      young singers (ages 7–11) between 2021 and 2023, the studio focuses on
      sustainable technique, ear training, repertoire selection appropriate to
      each singer's stage of vocal development, and audition preparation.
    </p>

    <h2>Who I Teach</h2>
    <ul>
      <li>Singers ages 12–18 navigating the changing voice</li>
      <li>High school students preparing pre-college and conservatory auditions</li>
      <li>Young singers building healthy classical and crossover technique</li>
    </ul>

    <h2>What We Work On</h2>
    <ul>
      <li>Breath, posture, and resonance for the developing instrument</li>
      <li>Musicianship: sight-singing, theory, and ear training</li>
      <li>Repertoire selection by voice type and developmental stage</li>
      <li>Audition repertoire and performance preparation</li>
      <li>Foreign-language diction (English, Spanish, Italian, German, French)</li>
    </ul>

    <h2>Lesson Details</h2>
    <p>
      For lesson formats, scheduling, and current rates,
      <a href="/contact/?subject=Voice%20lesson%20inquiry">please get in touch</a>.
      I'll respond with availability and answer any questions about whether the
      studio is the right fit for your singer.
    </p>

    <p style="margin-top: 2.5rem;">
      <a href="/contact/?subject=Voice%20lesson%20inquiry" class="cta">
        Inquire about lessons →
      </a>
    </p>
  </Page>
</Layout>

<style>
  .cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    border-radius: 2px;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }
  .cta:hover {
    opacity: 0.9;
  }
</style>
