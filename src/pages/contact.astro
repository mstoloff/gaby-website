---
import Layout from '../layouts/Layout.astro';

const subject = Astro.url.searchParams.get('subject') || '';
const subjectQuery = subject ? `?subject=${encodeURIComponent(subject)}` : '';
const email = 'gabrielastoloffbaez@gmail.com';
const mailto = `mailto:${email}${subjectQuery}`;
---

<Layout
  title="Contact — Gabriela Stoloff-Báez"
  description="Contact soprano Gabriela Stoloff-Báez for management inquiries, press requests, performance bookings, and voice lessons."
>
  <main class="contact-page">
    <section class="container contact-hero">
      <p class="micro">Contact · Bookings · Press</p>
      <h1>Get in touch.</h1>
    </section>

    <section class="container contact-body">
      {subject && (
        <p class="subject-prefill">
          Re: <strong>{subject}</strong>
        </p>
      )}

      <p class="contact-email">
        <a href={mailto}>{email}</a>
      </p>

      <div class="contact-prompts">
        <h2>What to include</h2>
        <dl>
          <div>
            <dt>Bookings</dt>
            <dd>Dates, venue, repertoire, and contact for the music director.</dd>
          </div>
          <div>
            <dt>Press</dt>
            <dd>Outlet, deadline, and what you need — interview, photos, EPK.</dd>
          </div>
          <div>
            <dt>Voice lessons</dt>
            <dd>Singer's age and background, goals, and in-person or online preference.</dd>
          </div>
        </dl>
      </div>
    </section>
  </main>
</Layout>

<style>
  .contact-page { padding-top: 1.5rem; }

  .contact-hero {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }
  .contact-hero h1 {
    margin-top: 1rem;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1.04;
  }

  .contact-body {
    /* Use margin-right to constrain visual width without auto-centering
       — .container's `margin: 0 auto` would otherwise shift this off-axis
       from the hero above. */
    max-width: none;
    padding-bottom: 6rem;
  }
  .contact-body > * {
    max-width: 720px;
  }

  .subject-prefill {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--color-oxblood);
    border-left: 2px solid var(--color-oxblood);
    padding-left: 1rem;
    margin: 0 0 2rem;
  }

  .contact-email {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.2;
    margin: 0 0 3.5rem;
  }
  .contact-email a {
    border-bottom: 1px solid var(--color-sand);
    padding-bottom: 0.1em;
  }
  .contact-email a:hover {
    border-bottom-color: currentColor;
  }

  .contact-prompts h2 {
    font-size: clamp(22px, 2.4vw, 28px);
    margin: 0 0 1.25rem;
    border-top: 1px solid var(--color-sand);
    padding-top: 1.25rem;
  }
  dl {
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  dl > div {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.25rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-sand);
  }
  dt {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.7;
    padding-top: 0.15rem;
  }
  dd {
    margin: 0;
  }

  @media (max-width: 700px) {
    dl > div {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
