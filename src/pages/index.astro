---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { buildHomepageGraph } from '../lib/schema';

import galaOrchestra from '../assets/images/gala-orchestra.webp';
import harveyMilk from '../assets/images/production-harvey-milk.webp';
import battleOfTheSexes from '../assets/images/production-battle-of-the-sexes.webp';
import mozartTrio from '../assets/images/production-mozart-trio.webp';

// --- Upcoming engagements ---
const allEvents = await getCollection('events');
const today = new Date();
const upcoming = allEvents
  .filter((e) => new Date(e.data.startDate) >= today)
  .sort((a, b) => +new Date(a.data.startDate) - +new Date(b.data.startDate));

const jsonLd = buildHomepageGraph(upcoming);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
const parseDate = (s: string) => new Date(s.length === 10 ? `${s}T00:00:00Z` : s);
const formatRange = (start: string, end?: string) => {
  const s = dateFmt.format(parseDate(start));
  if (!end) return s;
  return `${s} – ${dateFmt.format(parseDate(end))}`;
};

// --- Selected Productions band ---
// Tonal range: contemporary values-aligned → contemporary premiere → classical
// Mozart. Role names rendered in original language (Italian for Dorabella).
const selectedProductions = [
  {
    image: harveyMilk,
    role: 'Anne Kronenberg',
    work: 'Harvey Milk Reimagined',
    composer: 'Stewart Wallace',
    company: 'Opera Parallèle',
    year: 2025,
  },
  {
    image: battleOfTheSexes,
    role: 'Rosie Casals',
    work: 'Balls',
    composer: 'Laura Karpman',
    company: 'Opera Parallèle',
    year: 2024,
  },
  {
    image: mozartTrio,
    role: 'Dorabella',
    work: 'Così fan tutte',
    composer: 'Mozart',
    company: 'Oberlin Opera Theater',
    year: 2020,
  },
];

// --- Intro animation feature flag ---
// Toggle here. Setting to false suppresses the overlay entirely (no JS, no
// DOM node) so you can preview the homepage with and without the intro.
const INTRO_ENABLED = true;
---

<Layout
  title="Gabriela Stoloff-Báez — Puerto Rican Soprano | Des Moines Metro Opera 2026 Apprentice Artist"
  description="Puerto Rican soprano Gabriela Stoloff-Báez (Oberlin Conservatory, San Francisco Conservatory) performs with Opera Parallèle, Opera Theatre of St. Louis, and Seraphic Fire. Upcoming: Des Moines Metro Opera Apprentice Artist, summer 2026."
  type="profile"
  jsonLd={jsonLd}
>
  {INTRO_ENABLED && (
    <div id="intro-overlay" aria-hidden="true">
      <div class="intro-stack">
        <span class="intro-line one">Gabriela</span>
        <span class="intro-line two">
          Stoloff-B<span class="intro-a">a<span class="intro-accent" aria-hidden="true">´</span></span>ez
        </span>
      </div>
    </div>
  )}

  <main>
    {/* ───── ABOVE FOLD: name + role + pull-quote (no hero image) ───── */}
    <section class="hero container">
      <div class="hero-grid grid12">
        <div class="hero-block">
          <p class="micro role-line">Soprano</p>
          <h1 class="hero-name">
            Gabriela<br />Stoloff-Báez
          </h1>
        </div>
        <blockquote class="hero-quote pullquote">
          Repertoire that celebrates diversity, multiplicity, social justice, and humanity.
        </blockquote>
      </div>
    </section>

    {/* ───── FIRST SCROLL: framed gala image, cols 2–8 ───── */}
    <section class="container">
      <div class="grid12 gala-row">
        <figure class="figure-gala">
          <Image
            src={galaOrchestra}
            alt="Gabriela Stoloff-Báez performing with full orchestra in a cream gown, arms outstretched mid-aria."
            widths={[480, 960, 1440]}
            sizes="(min-width: 1024px) 60vw, 100vw"
            format="avif"
            quality={70}
            loading="eager"
          />
          <figcaption class="caption">
            Carceleras · <em>Las hijas del Zebedeo</em> · Center Stage Concert · Opera Theatre of Saint Louis · 2024
          </figcaption>
        </figure>
      </div>
    </section>

    {/* ───── SELECTED PRODUCTIONS three-up ───── */}
    <section class="container productions-section">
      <header class="section-head">
        <h2>Selected Productions</h2>
      </header>
      <div class="productions-grid">
        {
          selectedProductions.map((p) => (
            <figure class="production">
              <Image
                src={p.image}
                alt={`${p.role} in ${p.work}, ${p.company}, ${p.year}.`}
                widths={[480, 960, 1440]}
                sizes="(min-width: 1024px) 30vw, 100vw"
                format="avif"
                quality={70}
              />
              <figcaption class="caption">
                <span class="role-name">{p.role}</span> · <em>{p.work}</em> · {p.composer} · {p.company} · {p.year}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    {/* ───── UPCOMING ENGAGEMENTS — typographic list, no images ───── */}
    <section class="container engagements-section">
      <header class="section-head">
        <h2>Current &amp; Upcoming</h2>
      </header>
      {
        upcoming.length === 0 ? (
          <p>No engagements scheduled.</p>
        ) : (
          <ul class="engagements-list">
            {upcoming.map((e) => (
              <li class="engagement">
                <time class="micro" datetime={e.data.startDate}>
                  {formatRange(e.data.startDate, e.data.endDate)}
                </time>
                <h3 class="engagement-name">{e.data.name}</h3>
                <p class="engagement-loc">
                  {[e.data.venue, e.data.city, e.data.region].filter(Boolean).join(' · ')}
                </p>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </main>

  {INTRO_ENABLED && (
    <script is:inline>
      // Intro overlay — homepage, first visit per session, respects reduced motion.
      // Pure CSS handles the timing; this script only handles skip + cleanup +
      // sessionStorage gating.
      (function () {
        var overlay = document.getElementById('intro-overlay');
        if (!overlay) return;
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var seen = false;
        try { seen = sessionStorage.getItem('gsb_intro_seen') === '1'; } catch (e) {}
        if (seen || prefersReduced) {
          overlay.parentNode && overlay.parentNode.removeChild(overlay);
          return;
        }
        function dismiss() {
          if (!overlay.parentNode) return;
          overlay.parentNode.removeChild(overlay);
          try { sessionStorage.setItem('gsb_intro_seen', '1'); } catch (e) {}
        }
        // Auto-remove after the CSS animation completes (1.4s total).
        setTimeout(dismiss, 1400);
        ['keydown', 'click', 'touchstart'].forEach(function (ev) {
          overlay.addEventListener(ev, dismiss, { once: true, passive: true });
        });
      })();
    </script>
  )}
</Layout>

<style>
  main {
    padding-top: 2rem;
  }

  /* ---------- HERO ---------- */
  .hero {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  .hero-grid {
    align-items: end;
    row-gap: 3rem;
  }
  .hero-block {
    grid-column: 1 / span 7;
  }
  .role-line {
    margin: 0 0 1.5rem;
  }
  .hero-name {
    /* Slightly larger than base H1 — homepage gets the loudest treatment. */
    font-size: clamp(56px, 8vw, 96px);
    line-height: 1.04;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .hero-quote {
    grid-column: 8 / span 5;
    align-self: end;
  }
  @media (max-width: 768px) {
    .hero { padding-top: 3rem; padding-bottom: 3.5rem; }
    .hero-block, .hero-quote { grid-column: 1 / -1; }
    .hero-quote { margin-top: 1.25rem; }
  }

  /* ---------- GALA FIGURE (cols 2–8) ---------- */
  .gala-row {
    margin: 0 0 6rem;
  }
  .figure-gala {
    grid-column: 2 / span 7;
    margin: 0;
  }
  .figure-gala :global(img),
  .figure-gala :global(picture) {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 768px) {
    .figure-gala { grid-column: 1 / -1; }
    .gala-row { margin-bottom: 4rem; }
  }

  /* ---------- SECTION HEADERS ---------- */
  .section-head {
    margin-bottom: 2rem;
  }
  .section-head h2 {
    margin: 0;
    /* Section H2s lean a touch tighter than a freestanding H2. */
    font-size: clamp(28px, 3.4vw, 36px);
    line-height: 1.1;
  }

  /* ---------- PRODUCTIONS ---------- */
  .productions-section {
    margin-bottom: 6rem;
  }
  .productions-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--gutter);
  }
  .production figure,
  .production {
    margin: 0;
  }
  .production img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }
  .production .role-name {
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .productions-grid { grid-template-columns: 1fr; row-gap: 2.5rem; }
  }

  /* ---------- ENGAGEMENTS ---------- */
  .engagements-section { margin-bottom: 5rem; }
  .engagements-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-sand);
  }
  .engagement {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-sand);
  }
  .engagement time {
    align-self: start;
    padding-top: 0.4rem;
  }
  .engagement-name {
    margin: 0 0 0.25rem;
    font-weight: 500;
  }
  .engagement-loc {
    margin: 0;
    color: var(--color-ink);
    opacity: 0.65;
    font-size: 14px;
  }
  @media (max-width: 768px) {
    .engagement { grid-template-columns: 1fr; gap: 0.4rem; }
  }

  /* ---------- INTRO OVERLAY ---------- */
  /* Renders on top of the already-loaded homepage so LCP measures the H1
     under the overlay, not the overlay itself. The overlay's own contents
     are spans that fade in via @keyframes. */
  #intro-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-bone);
    display: grid;
    place-items: center;
    animation: introFade 0.2s ease 1.2s forwards;
    pointer-events: auto;
    /* contain reflow on a fixed overlay */
    contain: layout paint style;
  }
  .intro-stack {
    text-align: center;
    line-height: 1.05;
    color: var(--color-ink);
  }
  .intro-line {
    display: block;
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-weight: 400;
    font-size: clamp(48px, 7vw, 80px);
    letter-spacing: -0.012em;
    opacity: 0;
  }
  .intro-line.one {
    animation: introIn 0.3s ease-out 0.1s forwards;
  }
  .intro-line.two {
    animation: introIn 0.3s ease-out 0.5s forwards;
  }
  /* The accent draws in as a third beat. */
  .intro-a {
    position: relative;
    display: inline-block;
  }
  .intro-accent {
    position: absolute;
    top: -0.05em;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    transform-origin: 50% 50%;
    color: var(--color-oxblood);
    font-size: 0.78em;
    line-height: 1;
    animation: introAccent 0.2s ease-out 0.95s forwards;
    pointer-events: none;
  }
  @keyframes introIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes introAccent {
    from { transform: translateX(-50%) scaleX(0); }
    to   { transform: translateX(-50%) scaleX(1); }
  }
  @keyframes introFade {
    to { opacity: 0; visibility: hidden; }
  }
  @media (prefers-reduced-motion: reduce) {
    #intro-overlay { display: none; }
  }
</style>
