---
import Layout from '../layouts/Layout.astro';
import Page from '../components/Page.astro';

interface MediaItem {
  title: string;
  composer?: string;
  type: 'video' | 'audio';
  embedSrc: string;
}

const items: MediaItem[] = [
  {
    title: 'Si, mi chiamano Mimì',
    composer: 'Puccini · La bohème',
    type: 'video',
    embedSrc: 'https://www.youtube.com/embed/JayWkDNBRac',
  },
  {
    title: 'Dove sono i bei momenti',
    composer: 'Mozart · Le nozze di Figaro',
    type: 'video',
    embedSrc: 'https://www.youtube.com/embed/io8SFI0ZP_o',
  },
  {
    title: 'Air des Bijoux ("Jewel Song")',
    composer: 'Gounod · Faust',
    type: 'video',
    embedSrc: 'https://www.youtube.com/embed/8O3Q0gyMwK0',
  },
  {
    title: "Iolanta's Arioso",
    composer: 'Tchaikovsky · Iolanta',
    type: 'video',
    embedSrc: 'https://www.youtube.com/embed/BAXqC2w0YxQ',
  },
];
---

<Layout
  title="Media — Gabriela Stoloff-Báez"
  description="Video and audio recordings of soprano Gabriela Stoloff-Báez performing operatic arias from Puccini, Mozart, Gounod, and Tchaikovsky."
>
  <Page title="Media" lead="Selected video performances.">
    <div class="media-grid">
      {
        items.map((m) => (
          <article class="media-item">
            <div class="embed">
              <iframe
                src={m.embedSrc}
                title={m.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              />
            </div>
            <h3>{m.title}</h3>
            {m.composer && <p class="composer">{m.composer}</p>}
          </article>
        ))
      }
    </div>
  </Page>
</Layout>

<style>
  .media-grid {
    display: grid;
    gap: 2.5rem;
  }
  .media-item h3 {
    margin: 1rem 0 0.25rem;
  }
  .embed {
    position: relative;
    padding-top: 56.25%;
    background: #000;
  }
  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .composer {
    color: var(--color-muted);
    font-style: italic;
    margin: 0;
  }
</style>
