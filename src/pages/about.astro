---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import headshotGarden from '../assets/images/headshot-garden.webp';

// Layout note: the right column also has space below the portrait reserved
// for a future environmental/rehearsal-room portrait — drop a second <figure>
// inside .portrait-col when the asset arrives; no other changes required.
---

<Layout
  title="About — Gabriela Stoloff-Báez"
  description="Biography of soprano Gabriela Stoloff-Báez: Oberlin Conservatory and San Francisco Conservatory training, performances with Opera Parallèle, Opera Theatre of St. Louis, Seraphic Fire, Chautauqua, and Savannah Voice Festival."
  type="profile"
>
  <main>
    <section class="container about-hero">
      <p class="micro">Soprano · Bilingual · Sopranista puertorriqueña</p>
      <h1>About</h1>
    </section>

    <section class="container about-grid grid12">
      <div class="bio-col">
        <p class="lede">
          Gabriela Stoloff-Báez is a Puerto Rican soprano whose performances
          span opera, oratorio, and contemporary work — from Mozart and Handel
          to world premieres of Laura Karpman and Jodi Goble.
        </p>

        <p>
          She holds a Bachelor of Music in Voice Performance &amp; Musicology
          from the Oberlin Conservatory of Music and a Master of Music in
          Voice Performance from the San Francisco Conservatory of Music. She
          trained as a Gerdine Young Artist at Opera Theatre of Saint Louis in
          2023 and 2024 and at the Chautauqua Opera Company and Conservatory
          in 2020, 2022, and 2023.
        </p>

        <blockquote class="pullquote about-pullquote">
          Repertoire that celebrates diversity, multiplicity, social justice,
          and humanity.
        </blockquote>

        <p>
          Recent and upcoming engagements include performances with Opera
          Parallèle (<em>Harvey Milk Reimagined</em>, <em>Balls</em>), Opera
          Theatre of Saint Louis (<em>The Pirates of Penzance</em>,
          <em>Galileo Galilei</em>, <em>Susannah</em>, <em>The Barber of
          Seville</em>), Savannah Voice Festival (<em>Rigoletto</em>,
          <em>The Eleanors</em>), Seraphic Fire, and the Chautauqua Opera
          Company. In summer 2026 she joins Des Moines Metro Opera as an
          Apprentice Artist.
        </p>

        <p>
          Gaby recently transitioned voice types from mezzo-soprano to
          soprano. Her current audition repertoire centers on Marguerite
          (<em>Faust</em>), Mimì (<em>La bohème</em>), Agathe (<em>Der
          Freischütz</em>), and the title role in Floyd's <em>Susannah</em>.
        </p>

        <h2>Awards</h2>
        <ul class="award-list">
          <li>
            <span class="award-year">2024</span>
            <span class="award-name">Elihu Hyndman Memorial Award — Opera Theatre of Saint Louis</span>
          </li>
          <li>
            <span class="award-year">2023</span>
            <span class="award-name">Laffont Competition — Oregon District Winner &amp; Northwest Region Award Recipient</span>
          </li>
          <li>
            <span class="award-year">2021</span>
            <span class="award-name">Joan &amp; David Traitel Vocal Scholarship — San Francisco Conservatory</span>
          </li>
          <li>
            <span class="award-year">2021</span>
            <span class="award-name">Dix &amp; Didi Boring Endowed Scholarship for Voice — San Francisco Conservatory</span>
          </li>
          <li>
            <span class="award-year">2020</span>
            <span class="award-name">Margot Bos Stambler '84 Professional Development Award — Oberlin Conservatory</span>
          </li>
        </ul>

        <h2>Languages &amp; Skills</h2>
        <p>
          Bilingual <span lang="es">español / English</span>. Fluent Italian.
          German and French language studies. Theatrical and stage combat
          training; dance training; music theory. Experienced choral
          instructor, private voice teacher, and early-childhood music and
          Spanish educator.
        </p>

        <h2>Press &amp; Bookings</h2>
        <p>
          For management inquiries, press requests, and a downloadable EPK,
          <a href="/contact/">please get in touch</a>.
        </p>
      </div>

      <aside class="portrait-col">
        <figure class="portrait-figure">
          <Image
            src={headshotGarden}
            alt="Gabriela Stoloff-Báez, color portrait taken in a garden with dark green foliage behind."
            widths={[480, 720, 960]}
            sizes="(min-width: 1024px) 33vw, 100vw"
            format="avif"
            quality={75}
            loading="eager"
          />
          <figcaption class="caption">2024.</figcaption>
        </figure>
        {/* Reserved slot — second portrait will live here when the
            rehearsal-room/environmental shot arrives. */}
      </aside>
    </section>
  </main>
</Layout>

<style>
  main { padding-top: 1.5rem; }

  .about-hero {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }
  .about-hero h1 {
    margin-top: 1rem;
    font-size: clamp(48px, 6.5vw, 84px);
    line-height: 1.04;
  }

  .about-grid {
    align-items: start;
    padding-bottom: 5rem;
  }
  .bio-col {
    grid-column: 1 / span 7;
  }
  .portrait-col {
    grid-column: 9 / span 4;
    position: sticky;
    top: 2rem;
  }
  .portrait-figure { margin: 0; }
  .portrait-figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .lede {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-size: clamp(20px, 2vw, 24px);
    line-height: 1.45;
    margin: 0 0 2rem;
    color: var(--color-ink);
  }

  /* Pull-quote breaks across columns visually by hanging into the gutter. */
  .about-pullquote {
    margin: 2.5rem 0;
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-oxblood);
  }

  .bio-col h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: clamp(26px, 2.4vw, 30px);
  }

  .award-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .award-list li {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.25rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-sand);
  }
  .award-list li:first-child {
    border-top: 1px solid var(--color-sand);
  }
  .award-year {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-style: italic;
    color: var(--color-oxblood);
    font-size: 17px;
  }

  @media (max-width: 900px) {
    .bio-col { grid-column: 1 / -1; }
    .portrait-col {
      grid-column: 1 / -1;
      position: static;
      max-width: 360px;
      margin-bottom: 2.5rem;
      order: -1;
    }
  }
</style>
